    {
      "name": "Contracts",
      "item": [
        {
          "name": "Create Contract",
          "event": [
            {
              "listen": "test",
              "script": {
                "type": "text/javascript",
                "exec": [
                  "pm.test('Status code is 201', function () {",
                  "  pm.response.to.have.status(201);",
                  "});",
                  "",
                  "var data = pm.response.json();",
                  "if (data.contractId) {",
                  "  pm.collectionVariables.set('contractId', data.contractId);",
                  "}"
                ]
              }
            }
          ],
          "request": {
            "method": "POST",
            "header": [
              {
                "key": "Content-Type",
                "value": "application/json"
              }
            ],
            "body": {
              "mode": "raw",
              "raw": "{\n  \"merchantWalletId\": \"{{merchantWalletId}}\",\n  \"supplierWalletId\": \"{{supplierWalletId}}\",\n  \"amount\": {{contractAmount}},\n  \"dispatchDeadlineHours\": {{dispatchDeadlineHours}}\n}"
            },
            "url": {
              "raw": "{{baseUrl}}/contracts/create",
              "host": [
                "{{baseUrl}}"
              ],
              "path": [
                "contracts",
                "create"
              ]
            },
            "description": "Creates a credit contract and stores contractId."
          },
          "response": []
        },
