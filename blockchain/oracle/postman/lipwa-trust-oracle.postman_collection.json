    {
      "name": "Wallets",
      "item": [
        {
          "name": "Create Merchant Wallet",
          "event": [
            {
              "listen": "test",
              "script": {
                "type": "text/javascript",
                "exec": [
                  "pm.test('Status code is 201', function () {",
                  "  pm.response.to.have.status(201);",
                  "});",
                  "",
                  "var data = pm.response.json();",
                  "if (data.walletId) {",
                  "  pm.collectionVariables.set('merchantWalletId', data.walletId);",
                  "}"
                ]
              }
            }
          ],
          "request": {
            "method": "POST",
            "header": [
              {
                "key": "Content-Type",
                "value": "application/json"
              }
            ],
            "body": {
              "mode": "raw",
              "raw": "{\n  \"type\": \"merchant\",\n  \"ownerId\": \"{{merchantOwnerId}}\"\n}"
            },
            "url": {
              "raw": "{{baseUrl}}/wallets/create",
              "host": [
                "{{baseUrl}}"
              ],
              "path": [
                "wallets",
                "create"
              ]
            },
            "description": "Creates a merchant wallet and stores walletId to merchantWalletId."
          },
          "response": []
        },
